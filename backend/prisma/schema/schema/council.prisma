// Council Domain - Agents, Deliberations, Decisions, Veto, Union, Dissent

model agent_query_responses {
  id              String          @id
  query_id        String
  agent_id        String
  analysis        String
  sources         Json            @default("[]")
  confidence      Float
  created_at      DateTime        @default(now())
  agents          agents          @relation(fields: [agent_id], references: [id])
  council_queries council_queries @relation(fields: [query_id], references: [id], onDelete: Cascade)
}

model agents {
  id                    String                  @id
  code                  String                  @unique
  name                  String
  role                  String
  description           String
  avatar_url            String?
  system_prompt         String
  capabilities          Json                    @default("[]")
  constraints           Json                    @default("[]")
  model_config          Json                    @default("{}")
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now())
  updated_at            DateTime
  agent_query_responses agent_query_responses[]
  deliberation_messages deliberation_messages[]
}

model council_queries {
  id                    String                  @id
  organization_id       String
  user_id               String
  query                 String
  context               Json                    @default("{}")
  status                QueryStatus             @default(PENDING)
  response              Json?
  confidence            Float?
  processing_time       Int?
  created_at            DateTime                @default(now())
  completed_at          DateTime?
  agent_query_responses agent_query_responses[]
  users                 users                   @relation(fields: [user_id], references: [id])

  @@index([organization_id, created_at])
}

model decision_activities {
  id          String    @id
  decision_id String
  actor       String
  action      String
  details     Json?
  timestamp   DateTime  @default(now())
  decisions   decisions @relation(fields: [decision_id], references: [id], onDelete: Cascade)
}

model decision_blockers {
  id                   String    @id
  decision_id          String
  type                 String
  name                 String
  reason               String
  blocked_since        DateTime
  estimated_resolution DateTime?
  escalation_level     Int       @default(0)
  resolved_at          DateTime?
  decisions            decisions @relation(fields: [decision_id], references: [id], onDelete: Cascade)
}

model decision_dependencies {
  id                                                       String    @id
  decision_id                                              String
  depends_on_id                                            String
  created_at                                               DateTime  @default(now())
  decisions_decision_dependencies_decision_idTodecisions   decisions @relation("decision_dependencies_decision_idTodecisions", fields: [decision_id], references: [id], onDelete: Cascade)
  decisions_decision_dependencies_depends_on_idTodecisions decisions @relation("decision_dependencies_depends_on_idTodecisions", fields: [depends_on_id], references: [id], onDelete: Cascade)

  @@unique([decision_id, depends_on_id])
}

model decisions {
  id                                                                   String                  @id
  organization_id                                                      String
  user_id                                                              String
  title                                                                String
  description                                                          String
  category                                                             String?
  priority                                                             DecisionPriority        @default(MEDIUM)
  status                                                               DecisionStatus          @default(PENDING)
  department                                                           String?
  owner_name                                                           String?
  owner_email                                                          String?
  budget                                                               Float?
  timeframe                                                            String?
  deadline                                                             DateTime?
  estimated_daily_cost                                                 Float?
  total_cost_accrued                                                   Float?
  stakeholders                                                         String[]                @default([])
  created_at                                                           DateTime                @default(now())
  updated_at                                                           DateTime
  resolved_at                                                          DateTime?
  decision_activities                                                  decision_activities[]
  decision_blockers                                                    decision_blockers[]
  decision_dependencies_decision_dependencies_decision_idTodecisions   decision_dependencies[] @relation("decision_dependencies_decision_idTodecisions")
  decision_dependencies_decision_dependencies_depends_on_idTodecisions decision_dependencies[] @relation("decision_dependencies_depends_on_idTodecisions")
  executive_summaries                                                  executive_summaries[]

  @@index([organization_id])
  @@index([priority])
  @@index([status])
}

model deliberation_messages {
  id              String        @id
  deliberation_id String
  agent_id        String
  phase           String
  content         String
  target_agent_id String?
  sources         Json          @default("[]")
  confidence      Float?
  created_at      DateTime      @default(now())
  agents          agents        @relation(fields: [agent_id], references: [id])
  deliberations   deliberations @relation(fields: [deliberation_id], references: [id], onDelete: Cascade)

  @@index([deliberation_id, created_at])
}

model deliberations {
  id                    String                  @id
  organization_id       String
  question              String
  config                Json                    @default("{}")
  context               Json                    @default("{}")
  mode                  String?
  status                DeliberationStatus      @default(PENDING)
  current_phase         String?
  progress              Int                     @default(0)
  decision              Json?
  confidence            Float?
  started_at            DateTime?
  completed_at          DateTime?
  created_at            DateTime                @default(now())
  approvals             approvals[]
  deliberation_messages deliberation_messages[]
  deliberation_votes    deliberation_votes[]
  organizations         organizations           @relation(fields: [organization_id], references: [id])
  executive_summaries   executive_summaries[]
  decision_outcomes     decision_outcomes[]

  @@index([organization_id, status])
}

model decision_packets {
  id                    String    @id @default(uuid())
  run_id                String    @unique
  version               Int       @default(1)
  organization_id       String
  session_id            String
  user_id               String?
  deliberation_id       String?
  question              String
  context               String?
  recommendation        String
  confidence            Decimal   @db.Decimal(5, 4)
  confidence_bounds     Json      @default("{}")
  key_assumptions       Json      @default("[]")
  thresholds            Json      @default("{}")
  conditions_for_change Json      @default("[]")
  citations             Json      @default("[]")
  agent_contributions   Json      @default("[]")
  dissents              Json      @default("[]")
  consensus_reached     Boolean   @default(false)
  tool_calls            Json      @default("[]")
  approvals             Json      @default("[]")
  policy_gates          Json      @default("[]")
  artifact_hashes       Json      @default("{}")
  merkle_root           String
  signature             Json?
  signed_at             DateTime?
  regulatory_frameworks Json      @default("[]")
  retention_until       DateTime
  duration_ms           Int?
  created_at            DateTime  @default(now())
  completed_at          DateTime?
  exported_at           DateTime?

  @@index([organization_id])
  @@index([session_id])
  @@index([deliberation_id])
  @@index([run_id])
}

model executive_summaries {
  id              String         @id
  organization_id String
  deliberation_id String?
  decision_id     String?
  type            SummaryType
  title           String
  content         String
  key_points      Json           @default("[]")
  action_items    Json           @default("[]")
  participants    Json           @default("[]")
  risks           Json           @default("[]")
  recommendations Json           @default("[]")
  next_steps      Json           @default("[]")
  language        String         @default("en")
  generated_by    String
  created_at      DateTime       @default(now())
  updated_at      DateTime
  decisions       decisions?     @relation(fields: [decision_id], references: [id])
  deliberations   deliberations? @relation(fields: [deliberation_id], references: [id])

  @@index([organization_id])
  @@index([type])
}

model deliberation_votes {
  id              String   @id @default(uuid())
  deliberation_id String
  agent_role      String
  vote            String // approve, reject, abstain
  reasoning       String?
  confidence      Float?
  created_at      DateTime @default(now())

  deliberations deliberations @relation(fields: [deliberation_id], references: [id], onDelete: Cascade)

  @@index([deliberation_id])
}

model query_classifications {
  id              String   @id
  organization_id String?
  user_id         String?
  query           String
  query_hash      String
  classification  String
  confidence      Float
  routed_model    String
  actual_model    String?
  was_correct     Boolean?
  latency_ms      Int?
  metadata        Json     @default("{}")
  created_at      DateTime @default(now())

  @@index([classification])
  @@index([organization_id])
  @@index([routed_model])
}

model veto_rules {
  id              String        @id @default(uuid())
  organization_id String
  name            String
  description     String
  rule_type       String
  conditions      Json          @default("[]")
  enabled         Boolean       @default(true)
  veto_count      Int           @default(0)
  created_at      DateTime      @default(now())
  vetoes          veto_events[]

  @@index([organization_id])
}

model veto_events {
  id              String     @id @default(uuid())
  rule_id         String
  organization_id String
  target_type     String
  target_id       String
  reason          String
  severity        String
  created_at      DateTime   @default(now())
  rule            veto_rules @relation(fields: [rule_id], references: [id])

  @@index([organization_id])
}

model union_metrics {
  id              String   @id @default(uuid())
  organization_id String
  metric_name     String
  metric_value    Float
  department      String?
  period_start    DateTime
  period_end      DateTime
  trend           String   @default("stable")
  created_at      DateTime @default(now())

  @@index([organization_id])
}

model ghost_board_sessions {
  id                String   @id @default(uuid())
  organization_id   String
  title             String
  scenario          String
  board_composition Json     @default("[]")
  discussion        Json     @default("[]")
  insights          Json     @default("[]")
  status            String   @default("draft")
  created_by        String
  created_at        DateTime @default(now())

  @@index([organization_id])
}

model pre_mortem_analyses {
  id              String   @id @default(uuid())
  organization_id String
  decision_id     String?
  title           String
  failure_modes   Json     @default("[]")
  risk_factors    Json     @default("[]")
  mitigations     Json     @default("[]")
  overall_risk    Float?
  status          String   @default("draft")
  created_by      String
  created_at      DateTime @default(now())

  @@index([organization_id])
}

model decision_outcomes {
  id                   String   @id @default(uuid())
  organization_id      String
  deliberation_id      String
  decision_title       String
  decision_date        DateTime
  outcome_date         DateTime
  predictions          Json     @default("{}")
  dollar_impact        Decimal? @db.Decimal(18, 2)
  roi                  Decimal? @db.Decimal(10, 4)
  status               String   @default("pending")
  confidence_score     Decimal? @db.Decimal(5, 4)
  council_mode         String?
  participating_agents String[] @default([])
  voting_pattern       Json     @default("{}")
  notes                String?
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])
  deliberations deliberations @relation(fields: [deliberation_id], references: [id])

  @@index([organization_id])
  @@index([deliberation_id])
  @@index([status])
}

model agent_weight_history {
  id              String   @id @default(uuid())
  organization_id String
  agent_id        String
  agent_role      String
  previous_weight Decimal  @db.Decimal(5, 4)
  new_weight      Decimal  @db.Decimal(5, 4)
  adjustment      Decimal  @db.Decimal(5, 4)
  reason          String
  deliberation_id String?
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([agent_id])
}

model echo_collection_jobs {
  id                        String    @id @default(uuid())
  organization_id           String
  deliberation_id           String
  decision_title            String
  decision_date             DateTime
  scheduled_collection_date DateTime
  data_source_ids           String[]  @default([])
  metric_keys               String[]  @default([])
  status                    String    @default("scheduled") // scheduled, collecting, awaiting_review, completed, failed, cancelled
  collected_data            Json?
  collected_at              DateTime?
  error                     String?
  created_at                DateTime  @default(now())
  updated_at                DateTime  @default(now()) @updatedAt

  @@index([organization_id])
  @@index([deliberation_id])
  @@index([status])
  @@index([scheduled_collection_date])
}

model echo_patterns {
  id              String   @id @default(uuid())
  organization_id String
  pattern         String
  success_rate    Decimal  @db.Decimal(5, 2)
  sample_size     Int
  confidence      Decimal  @db.Decimal(5, 4)
  factors         String[] @default([])
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  @@index([organization_id])
}

model dissents {
  id                   String    @id @default(uuid())
  organization_id      String
  decision_id          String
  decision_title       String
  decision_date        DateTime
  decision_owner       String
  dissent_type         String // factual, risk, ethical, process, strategic, resource, other
  severity             String // advisory, formal_objection, blocking
  statement            String
  supporting_evidence  String[]  @default([])
  is_anonymous         Boolean   @default(false)
  dissenter_id         String
  dissenter_name       String
  dissenter_role       String?
  dissenter_department String?
  status               String    @default("pending") // pending, acknowledged, accepted, overruled, clarification_requested, escalated
  response_deadline    DateTime
  outcome_verified     Boolean   @default(false)
  dissenter_was_right  Boolean?
  outcome_verified_at  DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt
  ledger_hash          String
  ledger_timestamp     DateTime  @default(now())

  response      dissent_responses?
  organizations organizations      @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([dissenter_id])
  @@index([status])
  @@index([decision_id])
}

model dissent_responses {
  id                 String   @id @default(uuid())
  dissent_id         String   @unique
  responder_id       String
  responder_name     String
  responder_role     String
  response_type      String // accept, partial_accept, acknowledge_proceed, request_clarification, escalate_together
  reasoning          String
  mitigating_actions String[] @default([])
  created_at         DateTime @default(now())
  ledger_hash        String

  dissent dissents @relation(fields: [dissent_id], references: [id], onDelete: Cascade)

  @@index([responder_id])
}

model dissent_metrics {
  id                String   @id @default(uuid())
  organization_id   String   @unique
  total_dissents    Int      @default(0)
  active_dissents   Int      @default(0)
  response_rate     Decimal  @db.Decimal(5, 2)
  avg_response_time Decimal  @db.Decimal(8, 2)
  acceptance_rate   Decimal  @db.Decimal(5, 2)
  overall_accuracy  Decimal  @db.Decimal(5, 2)
  by_type           Json     @default("{}")
  by_severity       Json     @default("{}")
  retaliation_flags Int      @default(0)
  updated_at        DateTime @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])
}

model dissenter_profiles {
  id                  String   @id @default(uuid())
  user_id             String
  organization_id     String
  total_dissents      Int      @default(0)
  acknowledged        Int      @default(0)
  accepted_dissents   Int      @default(0)
  overruled_dissents  Int      @default(0)
  dissent_accuracy    Decimal  @db.Decimal(5, 2)
  verified_outcomes   Int      @default(0)
  correct_predictions Int      @default(0)
  is_high_accuracy    Boolean  @default(false)
  by_type             Json     @default("{}")
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@unique([user_id, organization_id])
  @@index([organization_id])
  @@index([user_id])
}

enum DecisionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DecisionStatus {
  PENDING
  BLOCKED
  DEFERRED
  ESCALATED
  APPROVED
  REJECTED
  IMPLEMENTED
}

enum DeliberationStatus {
  PENDING
  IN_PROGRESS
  AWAITING_APPROVAL
  COMPLETED
  CANCELLED
}

enum QueryStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SummaryType {
  COUNCIL_DELIBERATION
  DECISION_DNS
  PRE_MORTEM
  GHOST_BOARD
  DECISION_DEBT
  REGULATORY_ABSORB
  LIVE_DEMO
}
