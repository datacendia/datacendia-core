// Base Schema - Generator, Datasource, Users, Organizations, Auth

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model email_verifications {
  id         String   @id
  user_id    String   @unique
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([expires_at])
  @@index([token])
}

model organizations {
  id                       String                     @id
  name                     String
  slug                     String                     @unique
  industry                 String?
  company_size             String?
  settings                 Json                       @default("{}")
  created_at               DateTime                   @default(now())
  updated_at               DateTime
  deleted_at               DateTime?
  alerts                   alerts[]
  api_keys                 api_keys[]
  audit_logs               audit_logs[]
  data_sources             data_sources[]
  deliberations            deliberations[]
  metric_definitions       metric_definitions[]
  teams                    teams[]
  users                    users[]
  workflows                workflows[]
  crucible_simulations     crucible_simulations[]
  crucible_redteam_reports crucible_redteam_reports[]
  crucible_schedules       crucible_schedules[]
  crucible_sbom            crucible_sbom[]
  crucible_runtime_events  crucible_runtime_events[]

  // Panopticon - Regulation Engine
  panopticon_regulations panopticon_regulations[]
  panopticon_violations  panopticon_violations[]
  panopticon_forecasts   panopticon_forecasts[]

  // Aegis - Defense Intelligence
  aegis_signals   aegis_signals[]
  aegis_threats   aegis_threats[]
  aegis_briefings aegis_briefings[]

  // Eternal - Long Horizon Archive
  eternal_artifacts  eternal_artifacts[]
  eternal_migrations eternal_migrations[]
  eternal_succession eternal_succession[]

  // Symbiont - Ecosystem Engine
  symbiont_entities      symbiont_entities[]
  symbiont_opportunities symbiont_opportunities[]
  symbiont_relationships symbiont_relationships[]

  // Vox - Stakeholder Voice
  vox_stakeholders vox_stakeholders[]
  vox_impacts      vox_impacts[]
  vox_votes        vox_votes[]
  vox_assemblies   vox_assemblies[]

  // Crown Jewels - Echo, RedTeam, Gnosis
  decision_outcomes decision_outcomes[]

  // Apotheosis - Organizational Superintelligence
  apotheosis_runs         apotheosis_runs[]
  apotheosis_pattern_bans apotheosis_pattern_bans[]
  apotheosis_scores       apotheosis_scores[]
  apotheosis_configs      apotheosis_configs?

  // Dissent - Protected Disagreement
  dissents           dissents[]
  dissent_metrics    dissent_metrics?
  dissenter_profiles dissenter_profiles[]

  // OmniTranslate - 100+ Language Translation
  omnitranslate_glossaries omnitranslate_glossaries[]
  omnitranslate_glossary   omnitranslate_glossary[]
  omnitranslate_memory     omnitranslate_memory[]

  // Enterprise Department Services
  enterprise_contracts            enterprise_contracts[]
  enterprise_customers            enterprise_customers[]
  enterprise_services             enterprise_services[]
  enterprise_incidents            enterprise_incidents[]
  enterprise_legal_matters        enterprise_legal_matters[]
  enterprise_investors            enterprise_investors[]
  enterprise_production_lines     enterprise_production_lines[]
  enterprise_travel_requests      enterprise_travel_requests[]
  enterprise_skill_profiles       enterprise_skill_profiles[]
  enterprise_campaigns            enterprise_campaigns[]
  enterprise_crisis_responses     enterprise_crisis_responses[]
  enterprise_ideas                enterprise_ideas[]
  enterprise_patents              enterprise_patents[]
  enterprise_research_projects    enterprise_research_projects[]
  enterprise_culture_profiles     enterprise_culture_profiles[]
  enterprise_integration_roadmaps enterprise_integration_roadmaps[]
  enterprise_habitat_zones        enterprise_habitat_zones[]
  enterprise_regent_sessions      enterprise_regent_sessions[]

  // Schema Mappings
  schema_mappings schema_mappings[]

  // Regulatory Absorb V2
  regulatory_documents regulatory_documents[]

  // Enterprise Scheduler
  enterprise_scheduled_jobs enterprise_scheduled_jobs[]

  // Sports Vertical - Football/Soccer DDGI
  sports_transfer_decisions sports_transfer_decisions[]
  sports_contract_decisions sports_contract_decisions[]

  // DCII - Decision Crisis Immunization Infrastructure
  dcii_iiss_scores                dcii_iiss_scores[]
  dcii_media_assets               dcii_media_assets[]
  dcii_jurisdiction_assessments   dcii_jurisdiction_assessments[]
  dcii_timestamp_tokens           dcii_timestamp_tokens[]
  dcii_similarity_decisions       dcii_similarity_decisions[]

  // Evidence Vault - Decision Packet Management
  evidence_vault_packets          evidence_vault_packets[]

  // SSO - Enterprise Single Sign-On
  sso_identity_providers          sso_identity_providers[]
}

model password_resets {
  id         String    @id
  user_id    String
  token      String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([token])
  @@index([user_id])
}

model sessions {
  id                 String   @id
  user_id            String
  refresh_token_hash String
  user_agent         String?
  ip_address         String?
  expires_at         DateTime
  created_at         DateTime @default(now())
  users              users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model team_members {
  team_id    String
  user_id    String
  role       String   @default("member")
  created_at DateTime @default(now())
  teams      teams    @relation(fields: [team_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([team_id, user_id])
}

model teams {
  id              String         @id
  organization_id String
  name            String
  description     String?
  created_at      DateTime       @default(now())
  updated_at      DateTime
  team_members    team_members[]
  organizations   organizations  @relation(fields: [organization_id], references: [id])
}

model translations {
  id         String   @id
  key        String
  language   String
  namespace  String   @default("common")
  value      String
  context    String?
  verified   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime

  @@unique([key, language, namespace])
  @@index([language])
  @@index([namespace])
}

model user_language_preferences {
  id            String   @id
  user_id       String   @unique
  language      String   @default("en")
  date_format   String   @default("MM/DD/YYYY")
  time_format   String   @default("12h")
  timezone      String   @default("UTC")
  number_format String   @default("en-US")
  created_at    DateTime @default(now())
  updated_at    DateTime
}

model users {
  id                       String                 @id
  organization_id          String
  email                    String                 @unique
  password_hash            String?
  name                     String
  avatar_url               String?
  role                     UserRole               @default(VIEWER)
  status                   UserStatus             @default(ACTIVE)
  email_verified           Boolean                @default(false)
  email_verified_at        DateTime?
  preferences              Json                   @default("{}")
  last_login_at            DateTime?
  created_at               DateTime               @default(now())
  updated_at               DateTime
  deleted_at               DateTime?
  // MFA fields
  mfa_enabled              Boolean                @default(false)
  mfa_secret               String? // Encrypted TOTP secret
  mfa_backup_codes         String? // Encrypted JSON array of backup codes
  mfa_enabled_at           DateTime?
  // Notification preferences
  notification_preferences Json                   @default("{\"email\":true,\"inApp\":true,\"push\":false,\"slack\":false}")
  api_keys                 api_keys[]
  approvals                approvals[]
  audit_logs               audit_logs[]
  council_queries          council_queries[]
  metric_definitions       metric_definitions[]
  sessions                 sessions[]
  team_members             team_members[]
  organizations            organizations          @relation(fields: [organization_id], references: [id])
  crucible_simulations     crucible_simulations[]
  eternal_artifacts        eternal_artifacts[]

  @@index([email])
  @@index([organization_id])
}

enum UserRole {
  OWNER
  SUPER_ADMIN
  ADMIN
  ANALYST
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}
