// Intelligence Domain - Persona, Autopilot, Gnosis, Apotheosis, RedTeam

model persona_twins {
  id                 String                  @id @default(uuid())
  organization_id    String
  name               String
  role               String
  department         String?
  personality_config Json                    @default("{}")
  knowledge_domains  String[]                @default([])
  training_status    String                  @default("pending")
  accuracy_score     Float                   @default(0)
  interactions       Int                     @default(0)
  created_at         DateTime                @default(now())
  conversations      persona_conversations[]

  @@index([organization_id])
}

model persona_conversations {
  id           String        @id @default(uuid())
  twin_id      String
  user_id      String
  messages     Json          @default("[]")
  satisfaction Float?
  duration_ms  Int?
  created_at   DateTime      @default(now())
  twin         persona_twins @relation(fields: [twin_id], references: [id], onDelete: Cascade)

  @@index([twin_id])
}

model autopilot_rules {
  id              String                 @id @default(uuid())
  organization_id String
  name            String
  trigger_type    String
  trigger_config  Json                   @default("{}")
  action_type     String
  action_config   Json                   @default("{}")
  enabled         Boolean                @default(true)
  trigger_count   Int                    @default(0)
  created_at      DateTime               @default(now())
  executions      autopilot_executions[]

  @@index([organization_id])
}

model autopilot_executions {
  id          String          @id @default(uuid())
  rule_id     String
  status      String          @default("pending")
  duration_ms Int?
  executed_at DateTime        @default(now())
  rule        autopilot_rules @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@index([rule_id])
}

model redteam_simulations {
  id                String    @id @default(uuid())
  organization_id   String
  scenario_name     String
  objective         String
  adversary_profile String
  started_at        DateTime
  completed_at      DateTime?
  status            String    @default("pending")
  results           Json      @default("{}")
  created_at        DateTime  @default(now())

  vulnerabilities redteam_vulnerabilities[]

  @@index([organization_id])
  @@index([status])
}

model redteam_vulnerabilities {
  id                     String    @id @default(uuid())
  organization_id        String
  simulation_id          String?
  title                  String
  description            String
  attack_vector          String
  target_system          String
  steps                  Json      @default("[]")
  damage_estimate        Json      @default("{}")
  probability_of_success Decimal?  @db.Decimal(5, 2)
  detection_difficulty   Decimal?  @db.Decimal(5, 2)
  severity               String    @default("medium")
  status                 String    @default("active")
  discovered_at          DateTime  @default(now())
  mitigated_at           DateTime?

  simulation redteam_simulations? @relation(fields: [simulation_id], references: [id])
  patches    redteam_patches[]

  @@index([organization_id])
  @@index([severity])
  @@index([status])
}

model redteam_patches {
  id               String    @id @default(uuid())
  organization_id  String
  vulnerability_id String
  patch_type       String
  description      String
  reversible       Boolean   @default(true)
  original_state   Json?
  applied_at       DateTime?
  status           String    @default("pending")
  created_at       DateTime  @default(now())

  vulnerability redteam_vulnerabilities @relation(fields: [vulnerability_id], references: [id])

  @@index([organization_id])
  @@index([status])
}

model redteam_scores {
  id                    String   @id @default(uuid())
  organization_id       String
  overall_score         Int
  breakdown             Json     @default("{}")
  vulnerabilities_count Int      @default(0)
  critical_count        Int      @default(0)
  recommendations       String[] @default([])
  calculated_at         DateTime @default(now())

  @@index([organization_id])
}

model gnosis_learning_paths {
  id                 String    @id @default(uuid())
  organization_id    String
  user_id            String?
  title              String
  description        String
  source_decision_id String?
  modules            Json      @default("[]")
  estimated_duration Int       @default(0)
  difficulty         String    @default("intermediate")
  skills             String[]  @default([])
  progress           Int       @default(0)
  status             String    @default("not_started")
  deadline           DateTime?
  created_at         DateTime  @default(now())
  completed_at       DateTime?

  @@index([organization_id])
  @@index([user_id])
  @@index([status])
}

model gnosis_decision_impacts {
  id                      String   @id @default(uuid())
  organization_id         String
  deliberation_id         String
  decision_title          String
  affected_roles          String[] @default([])
  required_skills         String[] @default([])
  urgency                 String   @default("within_week")
  impact_level            String   @default("moderate")
  learning_path_ids       String[] @default([])
  estimated_reskill_hours Int      @default(0)
  affected_employee_count Int      @default(0)
  created_at              DateTime @default(now())

  @@index([organization_id])
  @@index([deliberation_id])
}

model gnosis_assessments {
  id              String    @id @default(uuid())
  user_id         String
  organization_id String
  skill           String
  questions       Json      @default("[]")
  results         Json?
  status          String    @default("pending")
  started_at      DateTime  @default(now())
  completed_at    DateTime?

  @@index([user_id])
  @@index([organization_id])
  @@index([skill])
}

model gnosis_skill_profiles {
  id              String    @id @default(uuid())
  user_id         String    @unique
  organization_id String
  skills          Json      @default("{}")
  strengths       String[]  @default([])
  gaps            String[]  @default([])
  learning_style  String    @default("reading")
  preferred_pace  String    @default("self_paced")
  last_assessment DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt

  @@index([organization_id])
}

model gnosis_analytics {
  id                 String   @id @default(uuid())
  organization_id    String
  period_start       DateTime
  period_end         DateTime
  total_learners     Int      @default(0)
  active_learners    Int      @default(0)
  completed_paths    Int      @default(0)
  avg_completion     Decimal  @db.Decimal(5, 2)
  avg_time_hours     Decimal  @db.Decimal(8, 2)
  skill_growth       Json     @default("{}")
  decision_readiness Decimal  @db.Decimal(5, 2)
  created_at         DateTime @default(now())

  @@index([organization_id])
  @@index([period_start, period_end])
}

model apotheosis_runs {
  id                       String    @id @default(uuid())
  organization_id          String
  started_at               DateTime  @default(now())
  completed_at             DateTime?
  status                   String    @default("scheduled") // running, completed, failed, scheduled
  scenarios_tested         Int       @default(0)
  scenarios_survived       Int       @default(0)
  survival_rate            Decimal   @db.Decimal(5, 2)
  critical_count           Int       @default(0)
  high_count               Int       @default(0)
  medium_count             Int       @default(0)
  low_count                Int       @default(0)
  apotheosis_score         Decimal   @db.Decimal(5, 2)
  previous_score           Decimal   @db.Decimal(5, 2)
  score_delta              Decimal   @db.Decimal(5, 2)
  shadow_council_instances Int       @default(0)
  compute_hours            Decimal   @db.Decimal(8, 2)
  duration_minutes         Int       @default(0)
  created_at               DateTime  @default(now())

  weaknesses          apotheosis_weaknesses[]
  auto_patches        apotheosis_auto_patches[]
  escalations         apotheosis_escalations[]
  upskill_assignments apotheosis_upskill_assignments[]

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
  @@index([started_at])
}

model apotheosis_weaknesses {
  id               String    @id @default(uuid())
  run_id           String
  title            String
  description      String
  category         String // financial, operational, competitive, regulatory, reputational, technical, human, black_swan
  severity         String // critical, high, medium, low
  exploit_scenario String
  damage_estimate  Decimal   @db.Decimal(12, 2)
  fix_complexity   String // trivial, easy, moderate, complex, requires_redesign
  recommended_fix  String
  auto_fixable     Boolean   @default(false)
  status           String    @default("new") // new, auto_patched, escalated, acknowledged, deferred, rejected
  discovered_at    DateTime  @default(now())
  resolved_at      DateTime?

  run apotheosis_runs @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@index([severity])
  @@index([status])
}

model apotheosis_auto_patches {
  id                 String   @id @default(uuid())
  run_id             String
  weakness_id        String
  patch_type         String // policy_adjustment, access_control, workflow_modification, council_tuning, alert_creation, config_change
  description        String
  before_state       String
  after_state        String
  reversible         Boolean  @default(true)
  budget_impact      Decimal  @db.Decimal(12, 2)
  applied_at         DateTime @default(now())
  status             String   @default("applied") // applied, rolled_back, failed
  rollback_available Boolean  @default(true)

  run apotheosis_runs @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@index([status])
}

model apotheosis_escalations {
  id                    String    @id @default(uuid())
  run_id                String
  weakness_id           String
  title                 String
  description           String
  severity              String // critical, high
  reason                String
  estimated_cost_to_fix Decimal   @db.Decimal(12, 2)
  risk_if_not_fixed     Decimal   @db.Decimal(12, 2)
  assigned_to           String[]  @default([])
  deadline              DateTime
  status                String    @default("pending") // pending, approved, rejected, deferred
  response_at           DateTime?
  response              String?
  created_at            DateTime  @default(now())

  run apotheosis_runs @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@index([status])
  @@index([deadline])
}

model apotheosis_upskill_assignments {
  id              String    @id @default(uuid())
  run_id          String
  user_id         String
  user_name       String
  skill_gap       String
  weakness_id     String
  training_module String
  estimated_hours Int
  deadline        DateTime
  status          String    @default("assigned") // assigned, in_progress, completed, overdue
  progress        Int       @default(0)
  started_at      DateTime?
  completed_at    DateTime?
  created_at      DateTime  @default(now())

  run apotheosis_runs @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id])
  @@index([user_id])
  @@index([status])
}

model apotheosis_pattern_bans {
  id                String   @id @default(uuid())
  organization_id   String
  pattern           String
  description       String
  instances         Json     @default("[]")
  failure_rate      Decimal  @db.Decimal(5, 2)
  total_cost        Decimal  @db.Decimal(12, 2)
  banned_at         DateTime @default(now())
  banned_by         String   @default("apotheosis") // apotheosis, human
  status            String   @default("active") // active, lifted
  override_requires String

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
}

model apotheosis_scores {
  id                String   @id @default(uuid())
  organization_id   String
  overall           Decimal  @db.Decimal(5, 2)
  red_team_survival Decimal  @db.Decimal(5, 2)
  weakness_closure  Decimal  @db.Decimal(5, 2)
  decision_success  Decimal  @db.Decimal(5, 2)
  human_readiness   Decimal  @db.Decimal(5, 2)
  pattern_health    Decimal  @db.Decimal(5, 2)
  recorded_at       DateTime @default(now())

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([recorded_at])
}

model apotheosis_configs {
  id                    String   @id @default(uuid())
  organization_id       String   @unique
  run_frequency         String   @default("nightly")
  run_time              String   @default("03:00")
  scenario_count        Int      @default(1000)
  auto_patch_threshold  Decimal  @db.Decimal(12, 2)
  escalation_timeout    Int      @default(72)
  pattern_ban_threshold Int      @default(3)
  training_deadline     Int      @default(72)
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])
}
