// DCII Domain - Decision Crisis Immunization Infrastructure
// CendiaDCII™ — 5 gap-closing services with database persistence

// =============================================================================
// IISS - Institutional Immune System Score
// =============================================================================

model dcii_iiss_scores {
  id                String   @id @default(uuid())
  organization_id   String
  organization_name String
  overall_score     Int      // 0-1000
  band              String   // critical, vulnerable, developing, resilient, exceptional
  certification     String   @default("none") // none, bronze, silver, gold, platinum
  previous_score    Int?
  previous_band     String?
  trend             String   @default("stable") // improving, stable, declining
  change_amount     Int      @default(0)
  percentile        Float?
  assessment_id     String
  valid_until       DateTime
  data              Json     // Full IISSScore object (dimensions, recommendations, insurance impact, etc.)
  integrity_hash    String
  created_at        DateTime @default(now())

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([band])
  @@index([created_at])
}

model dcii_iiss_assessments {
  id              String    @id @default(uuid())
  organization_id String
  status          String    @default("pending") // pending, in_progress, completed, expired, revoked
  initiated_by    String
  data            Json      // Full IISSAssessment object
  completed_at    DateTime?
  created_at      DateTime  @default(now())

  @@index([organization_id])
  @@index([status])
}

model dcii_iiss_history {
  id              String   @id @default(uuid())
  organization_id String
  score           Int
  band            String
  event_type      String   // assessment, recalculation, manual_adjustment
  data            Json     // Full IISSHistoryEntry object
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([created_at])
}

// =============================================================================
// Synthetic Media Authentication
// =============================================================================

model dcii_media_assets {
  id              String   @id @default(uuid())
  organization_id String
  file_name       String
  media_type      String   // image, video, audio, document
  mime_type       String
  content_hash    String
  status          String   @default("signed") // signed, verified, tampered, disputed, revoked
  created_by      String
  data            Json     // Full MediaAsset object (c2pa manifest, chain of custody, etc.)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
  @@index([content_hash])
}

model dcii_media_assessments {
  id              String   @id @default(uuid())
  asset_id        String
  organization_id String
  verdict         String   // authentic, suspicious, manipulated, inconclusive
  confidence      Float
  analyzed_by     String
  data            Json     // Full AuthenticityAssessment object (indicators, analysis results)
  created_at      DateTime @default(now())

  @@index([asset_id])
  @@index([organization_id])
}

// =============================================================================
// Cross-Jurisdiction Compliance Conflict Detection
// =============================================================================

model dcii_jurisdiction_assessments {
  id                String   @id @default(uuid())
  organization_id   String
  organization_name String
  jurisdictions     String[] // Array of jurisdiction codes
  assessed_by       String
  conflict_count    Int      @default(0)
  status            String   @default("completed")
  data              Json     // Full CrossJurisdictionAssessment object
  created_at        DateTime @default(now())

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([created_at])
}

model dcii_jurisdiction_conflicts {
  id              String   @id @default(uuid())
  organization_id String
  assessment_id   String
  severity        String   // critical, high, medium, low
  conflict_type   String   // direct_contradiction, partial_overlap, timing_conflict, scope_conflict, enforcement_gap
  jurisdiction_a  String
  jurisdiction_b  String
  framework_a     String
  framework_b     String
  status          String   @default("detected") // detected, analyzing, resolved, accepted_risk, mitigated
  data            Json     // Full RegulatoryConflict object
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([severity])
  @@index([status])
}

model dcii_jurisdiction_evidence_packets {
  id              String   @id @default(uuid())
  organization_id String
  jurisdiction    String
  framework       String
  packet_type     String   @default("compliance_report")
  generated_by    String
  data            Json     // Full JurisdictionEvidencePacket object
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([jurisdiction])
}

model dcii_jurisdiction_good_faith_docs {
  id              String   @id @default(uuid())
  conflict_id     String
  organization_id String
  signed_by       String
  data            Json     // Full GoodFaithDocument object
  created_at      DateTime @default(now())

  @@index([conflict_id])
  @@index([organization_id])
}

// =============================================================================
// RFC 3161 Timestamp Authority
// =============================================================================

model dcii_timestamp_tokens {
  id              String    @id @default(uuid())
  organization_id String
  data_hash       String
  hash_algorithm  String    @default("SHA-256")
  data_type       String    @default("generic") // decision, deliberation, evidence, override, dissent, compliance, document, media, generic
  description     String
  reference_id    String?
  status          String    @default("valid") // valid, verified, expired, revoked, superseded
  has_external    Boolean   @default(false)
  has_blockchain  Boolean   @default(false)
  data            Json      // Full TimestampToken object
  created_at      DateTime  @default(now())
  expires_at      DateTime?

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([data_hash])
  @@index([reference_id])
  @@index([status])
}

model dcii_timestamp_verifications {
  id          String   @id @default(uuid())
  token_id    String
  verified_by String
  valid       Boolean
  data        Json     // Full TimestampVerification object
  created_at  DateTime @default(now())

  @@index([token_id])
}

model dcii_timestamp_batches {
  id              String   @id @default(uuid())
  organization_id String
  item_count      Int
  status          String   @default("completed")
  data            Json     // Full BatchTimestampRequest object
  created_at      DateTime @default(now())

  @@index([organization_id])
}

// =============================================================================
// Evidence Vault - Decision Packet Management
// =============================================================================

model evidence_vault_packets {
  id                  String   @id
  decision_id         String
  decision_title      String
  status              String   @default("draft") // draft, under_review, approved, locked, superseded
  mode                String   @default("operational") // due_diligence, war_room, compliance, strategic, operational
  owner_id            String
  owner_name          String
  owner_email         String
  owner_role          String
  owner_department    String
  business_unit       String
  organization_id     String
  data_source_id      String?
  policy_pack_version String   @default("v1.0.0")
  signature_valid     Boolean  @default(false)
  integrity_hash      String
  version             Int      @default(1)
  superseded_by       String?
  systems_impacted    String[]
  compliance_frameworks String[]
  retention_until     DateTime
  data                Json     // Full DecisionPacket object (attachments, dissents, vetoes, overrides, access log, workflows)
  generated_at        DateTime @default(now())
  signed_at           DateTime?
  locked_at           DateTime?
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
  @@index([mode])
  @@index([decision_id])
  @@index([business_unit])
  @@index([generated_at])
}

// =============================================================================
// Decision Similarity Engine
// =============================================================================

model dcii_similarity_decisions {
  id              String   @id @default(uuid())
  organization_id String
  title           String
  question        String   @db.Text
  context         String   @db.Text
  decision_type   String
  department      String
  urgency         String   @default("medium") // low, medium, high, critical
  outcome         String?  // successful, partially_successful, failed, too_early, unknown
  override        Boolean  @default(false)
  decided_by      String
  decided_at      DateTime
  tags            String[]
  keywords        String[]
  data            Json     // Full DecisionRecord object
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([department])
  @@index([decision_type])
  @@index([outcome])
  @@index([decided_at])
}

model dcii_similarity_results {
  id              String   @id @default(uuid())
  organization_id String
  query_title     String
  match_count     Int
  data            Json     // Full SimilaritySearchResult object
  created_at      DateTime @default(now())

  @@index([organization_id])
}

model dcii_similarity_patterns {
  id              String   @id @default(uuid())
  organization_id String
  pattern_type    String   // recurring_failure, override_pattern, department_blindspot, seasonal_pattern, escalation_pattern
  severity        String   // critical, high, medium, low
  confidence      Float
  data            Json     // Full DecisionPattern object
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([pattern_type])
  @@index([severity])
}

// =============================================================================
// CendiaBiasGuard — NLP Bias Detection Results
// =============================================================================

model bias_analysis_results {
  id                 String   @id @default(uuid())
  organization_id    String?
  deliberation_id    String?
  input_hash         String
  detection_count    Int
  overall_bias_score Int      // 0-100
  engine             String   // ollama-nlp, statistical-fallback
  model_used         String?
  analysis_time_ms   Int
  summary            String   @db.Text
  detections         Json     // Array of BiasDetection objects
  created_at         DateTime @default(now())

  @@index([organization_id])
  @@index([deliberation_id])
  @@index([overall_bias_score])
  @@index([created_at])
}

model bias_detection_items {
  id            String   @id @default(uuid())
  analysis_id   String
  category      String   // anchoring, confirmation, availability, sunk_cost, authority, groupthink, recency, framing, survivorship, dunning_kruger
  confidence    Float
  severity      String   // low, medium, high, critical
  evidence      String   @db.Text
  explanation   String   @db.Text
  mitigation    String   @db.Text
  created_at    DateTime @default(now())

  @@index([analysis_id])
  @@index([category])
  @@index([severity])
}
