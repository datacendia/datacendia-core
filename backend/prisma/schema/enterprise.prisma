  prior_art          Json      @default("[]")
  maintenance_fees   Json      @default("[]")
  estimated_value    Decimal?  @db.Decimal(15, 2)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
}

model enterprise_research_projects {
  id              String    @id @default(uuid())
  organization_id String
  title           String
  description     String    @db.Text
  lead_id         String
  lead_name       String
  team            Json      @default("[]")
  status          String    @default("proposed") // proposed, active, on_hold, completed, cancelled
  budget          Decimal   @db.Decimal(15, 2)
  spent           Decimal   @default(0) @db.Decimal(15, 2)
  start_date      DateTime?
  target_end_date DateTime?
  milestones      Json      @default("[]")
  publications    Json      @default("[]")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
}

model enterprise_culture_profiles {
  id              String   @id @default(uuid())
  organization_id String
  company_name    String
  dimensions      Json     @default("{}")
  values          Json     @default("[]")
  work_style      Json     @default("{}")
  decision_making Json     @default("{}")
  communication   Json     @default("{}")
  assessed_at     DateTime @default(now())

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
}

model enterprise_integration_roadmaps {
  id                  String    @id @default(uuid())
  organization_id     String
  name                String
  acquirer_id         String
  target_id           String
  status              String    @default("planning") // planning, in_progress, completed
  compatibility_score Int?
  phases              Json      @default("[]")
  risks               Json      @default("[]")
  synergies           Json      @default("[]")
  progress            Decimal   @default(0) @db.Decimal(5, 2)
  start_date          DateTime?
  target_end_date     DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([status])
}

model enterprise_habitat_zones {
  id                String   @id @default(uuid())
  organization_id   String
  name              String
  floor             Int
  building          String
  type              String // office, meeting, focus, collaboration, wellness, cafeteria, lobby
