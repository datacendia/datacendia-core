model enterprise_regent_sessions {
  id                String   @id @default(uuid())
  organization_id   String
  question          String   @db.Text
  context           String?  @db.Text
  advisor_responses Json     @default("[]")
  synthesis         String?  @db.Text
  mirror_truth      String?  @db.Text
  created_at        DateTime @default(now())

  organizations organizations @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([created_at])
}

model enterprise_scheduled_jobs {
  id                   String    @id
  organization_id      String
  job_type             String // apotheosis_nightly, security_assessment, sbom_scan, etc.
  name                 String
  description          String?
  cron_expression      String
  timezone             String    @default("UTC")
  config               Json      @default("{}")
  status               String    @default("scheduled") // scheduled, running, completed, failed, cancelled
  enabled              Boolean   @default(true)
  last_run_at          DateTime?
  last_run_status      String? // success, failure
  last_run_duration_ms Int?
  last_run_error       String?
  next_run_at          DateTime?
  total_runs           Int       @default(0)
  successful_runs      Int       @default(0)
  failed_runs          Int       @default(0)
  created_at           DateTime  @default(now())
  created_by           String
  updated_at           DateTime  @updatedAt

  executions   enterprise_job_executions[]
  organization organizations               @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([job_type])
  @@index([enabled])
  @@index([next_run_at])
}

model enterprise_job_executions {
  id              String    @id
  job_id          String
  organization_id String
  job_type        String
  started_at      DateTime  @default(now())
  completed_at    DateTime?
  duration_ms     Int?
  status          String // running, success, failure
  result          Json      @default("{}")
  error           String?
  triggered_by    String // schedule, manual, system
  execution_hash  String // SHA-256 for audit

  job enterprise_scheduled_jobs @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([job_id])
  @@index([organization_id])
  @@index([started_at])
  @@index([status])
}

// =============================================================================
// CendiaInsure - AI Insurance Integration
// =============================================================================

model insurance_policies {
  id                String   @id @default(uuid())
  policy_number     String   @unique
  organization_id   String
  coverage_type     String   // errors_omissions, cyber_liability, product_liability, etc.
  coverage_limit    Float
  deductible        Float
  premium           Float
  risk_score        Float
  risk_tier         String   // low, medium, high, critical
  status            String   @default("active") // quoted, bound, active, expired, cancelled, claimed
  effective_date    DateTime
  expiration_date   DateTime
  data              Json     // Full InsurancePolicy object
  created_by        String
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  claims insurance_claims[]

  @@index([organization_id])
  @@index([status])
  @@index([policy_number])
}

model insurance_quotes {
  id              String   @id @default(uuid())
  organization_id String
  coverage_type   String
  requested_limit Float
  premium         Float
  risk_score      Float
  risk_tier       String
  status          String   @default("pending") // pending, accepted, declined, expired
  data            Json     // Full InsuranceQuote object
  quoted_at       DateTime @default(now())
  valid_until     DateTime

  @@index([organization_id])
  @@index([status])
}

model insurance_claims {
  id              String    @id @default(uuid())
  claim_number    String    @unique
  policy_id       String
  policy_number   String
  claim_amount    Float
  claim_type      String
  status          String    @default("filed") // filed, under_review, approved, denied, paid, closed
  decision_id     String?
  data            Json      // Full Claim object
  filed_at        DateTime  @default(now())
  resolved_at     DateTime?

  policy insurance_policies @relation(fields: [policy_id], references: [id])

  @@index([policy_id])
  @@index([status])
  @@index([claim_number])
}

// =============================================================================
// CendiaSSO — Enterprise Single Sign-On
// =============================================================================

model sso_identity_providers {
  id              String    @id @default(uuid())
  organization_id String
  name            String
  protocol        String    // saml2, oidc, scim2
  issuer          String
  metadata_url    String?
  sso_url         String?
  slo_url         String?
  certificate     String?   @db.Text
  client_id       String?
  client_secret   String?
  authorization_url String?
  token_url       String?
  user_info_url   String?
  jwks_uri        String?
  scopes          Json      @default("[]")
  enabled         Boolean   @default(true)
  mfa_required    Boolean   @default(false)
  last_used_at    DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt

  organizations organizations    @relation(fields: [organization_id], references: [id])
  sessions      sso_sessions[]

  @@index([organization_id])
  @@index([protocol])
}

model sso_sessions {
  id                   String   @id @default(uuid())
  user_id              String
  organization_id      String
  identity_provider_id String
  protocol             String   // saml2, oidc
  email                String
  name                 String
  roles                Json     @default("[]")
  groups               Json     @default("[]")
  device_fingerprint   String
  mfa_verified         Boolean  @default(false)
  session_hash         String
  expires_at           DateTime
  created_at           DateTime @default(now())
  revoked_at           DateTime?

  identity_provider sso_identity_providers @relation(fields: [identity_provider_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([user_id])
  @@index([expires_at])
}

model sso_scim_events {
  id              String   @id @default(uuid())
  organization_id String
  event_type      String   // user.create, user.update, user.delete, group.create, group.update
  payload         Json
  processed       Boolean  @default(true)
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([event_type])
}
