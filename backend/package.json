{
  "name": "datacendia-api",
  "version": "1.0.0",
  "description": "Datacendia Platform Backend API",
  "main": "dist/index.js",
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc",
    "build:docker": "tsc -p tsconfig.docker.json",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "tsx scripts/setup.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "build:community": "tsc -p tsconfig.community.json",
    "check:boundary": "node ../scripts/check-community-boundary.mjs",
    "seed:demo": "tsx prisma/seed-full-demo.ts && tsx prisma/seed-council-showcase.ts",
    "seed:showcase": "tsx prisma/seed-council-showcase.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.995.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/client-sts": "^3.940.0",
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.29.1",
    "@clickhouse/client": "^1.14.0",
    "@noble/curves": "^2.0.1",
    "@noble/post-quantum": "^0.5.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.2",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-prometheus": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@prisma/client": "^5.7.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.5.0",
    "bullmq": "^5.66.0",
    "casbin": "^5.45.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.2",
    "form-data": "^4.0.5",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "helmet": "^7.2.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "jose": "^5.2.0",
    "jsforce": "^3.10.8",
    "keycloak-connect": "^26.1.1",
    "mammoth": "^1.11.0",
    "minio": "^8.0.6",
    "mongodb": "^6.3.0",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "neo4j-driver": "^5.15.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.11",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "redis": "^5.10.0",
    "snarkjs": "^0.7.6",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsforce": "^1.11.6",
    "@types/minio": "^7.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.25",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.17.4",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@vitest/ui": "^4.0.15",
    "jest": "^30.2.0",
    "prisma": "^5.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
