# ============================================
# DATACENDIA PLATFORM - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# Default values match docker-compose.unified.yml

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ============================================
# DATABASE - PostgreSQL
# ============================================
POSTGRES_USER=datacendia
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=datacendia
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB}?schema=public

# ============================================
# CACHE - Redis
# ============================================
REDIS_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6380

# ============================================
# GRAPH DATABASE - Neo4j
# ============================================
NEO4J_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# ============================================
# AUTHENTICATION - JWT
# ============================================
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_64_CHAR_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_SECURE_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# ENCRYPTION
# ============================================
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY

# ============================================
# AI / LLM
# ============================================
# Ollama (Local) - default
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:latest

# OpenAI (Cloud) - optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# CORS & SECURITY
# ============================================
CORS_ORIGIN=https://app.datacendia.com
TRUSTED_PROXIES=nginx

# ============================================
# EMAIL (Choose one provider)
# ============================================
# SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=noreply@datacendia.com

# Or SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@datacendia.com

# ============================================
# BILLING - Stripe
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=
DATADOG_API_KEY=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_DEMO_MODE=false
ENABLE_OLLAMA=true
ENABLE_OPENAI=false
ENABLE_BILLING=false

# ============================================
# FRONTEND BUILD ARGS
# ============================================
VITE_API_URL=https://api.datacendia.com/api/v1
VITE_WS_URL=wss://api.datacendia.com
VITE_APP_NAME=Datacendia
VITE_APP_VERSION=1.0.0
