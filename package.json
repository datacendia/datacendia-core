{
  "name": "datacendia-core",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "vite build",
    "build:backend": "npm run build --workspace=backend",
    "build:all": "npm run build && npm run build:backend",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:backend": "npm run lint --workspace=backend",
    "lint:all": "npm run lint && npm run lint:backend",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "npm run typecheck --workspace=backend",
    "typecheck:all": "npm run typecheck && npm run typecheck:backend",
    "test": "vitest run",
    "test:backend": "npm run test --workspace=backend",
    "test:all": "npm run test && npm run test:backend",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:critical": "vitest run --config vitest.critical.config.ts --coverage",
    "test:contract": "vitest run tests/contract/",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "test:mutation": "stryker run",
    "test:chaos": "echo 'Run chaos tests in isolated environment'",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker-compose.production.yml up --build",
    "start:dev": "node scripts/start-dev.js",
    "start:all": "concurrently --kill-others \"docker-compose -f docker-compose.dev.yml up -d postgres redis\" \"npm run dev:all\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@formspree/react": "^3.0.0",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.21",
    "@types/cytoscape": "^3.21.9",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.1",
    "framer-motion": "^12.23.26",
    "i18next": "^25.7.3",
    "immer": "^11.0.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.1",
    "react-joyride": "^2.9.3",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.20.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "fast-xml-parser": "5.3.4",
    "elliptic": "6.6.1",
    "minio": {
      "fast-xml-parser": "5.3.4"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@pact-foundation/pact": "^13.1.0",
    "@playwright/test": "^1.58.0",
    "@stryker-mutator/core": "^9.5.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.15",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.31",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
